{
  "name": "ai-starter-3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm ": "^11"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit --run",
    "test:nuxt": "vitest --project nuxt --run",
    "test:e2e": "vitest --project e2e --run",
    "pretty:check": "prettier --check .",
    "pretty:write": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type:check": "nuxt typecheck",
    "ci:all": "npm run pretty:check && npm run type:check && npm run lint && npm run test:unit && npm run test:nuxt && npm run test:e2e",
    "rs:generate": "rulesync generate"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/i18n": "^10.2.3",
    "better-sqlite3": "^12.6.2",
    "nuxt": "^4.3.1",
    "swrv": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "rulesync": "^7.18.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
